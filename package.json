{
	"name": "rtlify",
	"version": "1.2.0",
	"description": "With this extension, you can make all mainstream AI chatbots right-to-left and apply your preferred custom font to them.",
	"type": "module",
	"private": true,
	"license": "GPL-3.0-only",
	"author": {
		"name": "Alireza Mohammadzadeh Nedamani",
		"url": "https://nedamani.ir"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/NedaMani/RTLify.git"
	},
	"bugs": {
		"url": "https://github.com/NedaMani/RTLify/issues"
	},
	"homepage": "https://github.com/NedaMani/RTLify#readme",
	"scripts": {
		"dev": "vite",
		"build": "pnpm run build:chrome && pnpm run build:firefox",
		"build:chrome": "cross-env VITE_BROWSER=chrome vite build",
		"build:firefox": "cross-env VITE_BROWSER=firefox vite build",
		"preview": "vite preview",
		"lint": "biome check --write .",
		"format": "biome format --write .",
		"prepare": "simple-git-hooks"
	},
	"dependencies": {
		"@crxjs/vite-plugin": "^2.7.1",
		"@tailwindcss/vite": "^4.3.3",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tailwindcss": "^4.3.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@types/chrome": "^0.2.2",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"cross-env": "^10.1.0",
		"typescript": "~7.0.2",
		"vite": "^8.1.5",
		"vite-plugin-zip-pack": "^1.2.4",
		"simple-git-hooks": "^2.13.1"
	},
	"packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
	"simple-git-hooks": {
		"pre-commit": "pnpm run lint",
		"pre-push": "pnpm run build"
	}
}
